# Config (contains secrets)
wp-config.php
# Uploads (too large for git)
/wp-content/uploads/
# Cache and temp
/wp-content/cache/
/wp-content/upgrade/
/wp-content/backup*/
# Keep themes and plugins
!/wp-content/
!/wp-content/themes/
!/wp-content/plugins/

# DRUPAL
sites/default/files/
sites/default/settings.php
sites/default/settings.local.php

# DATABASE DUMOS & DATA
*.sql
*.sql.gz
*.sqlite
*.sqlite3
*.sqlite-journal
# Allow Prisma migration SQL through the blanket *.sql rule above so a fresh
# checkout + "prisma migrate deploy" picks up every schema change.
!app/api/prisma/migrations/**/migration.sql
*.db
*.tar.gz

# Sensitive credentials
database_engine/login.txt
database_engine/cPanel.txt

# TERRAFOM
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfvars*
*.tfvars.json

# SCRAPER OUTPUT (can grow large)
cleanup_engine/page_scrapper/page_output*.json
cleanup_engine/page_scrapper/image_output*.json
cleanup_engine/page_scrapper/page_output*.md
cleanup_engine/*_output.json
cleanup_engine/page_source.json
cleanup_engine/pages_*.json

# CREATOR UPLOADS / PER-BATCH DATA
# Per-batch ETL workspace. Source docs + scripts are tracked; raw data,
# generated artifacts, credentials, and creator media never are.
creator_engine/bg_data_*.xlsx
creator_engine/creator_credentials.csv
creator_engine/images_*/
creator_engine/import_run/
creator_engine/new_ads_*/

# AUDIT ENGINE
# Per-run audit workspace: NSFW detection artifacts + a `for_delete/` record
# that may contain creator images. Never committed.
audit_engine/

# AI FOLDER & FILES
.claude
./claude
/claude
.secrets/

# Next.js build cache
**/tsconfig.tsbuildinfo

# local .env backups (contain secrets)
.env.bak*
