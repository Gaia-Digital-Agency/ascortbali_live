# PROJECT SPECIFIC IMAGE FOLDER

# Ad-hoc / transient transfer dump. Used to stage files between local and
# server (e.g. logo source uploads, image cleanup inspection bundles).
# Never source of truth — never committed.
references/files_transfer/

# WATERMARK PROCESSING FOLDERS
cleanup_engine/watermark/clean_reject/
cleanup_engine/watermark/debug/
cleanup_engine/watermark/need_work/
cleanup_engine/watermark/watermark_images/

# CLEAN IMAGES (served from GCS)
app/Assets/Creator/clean_image/

# NODE.JS / NEXT.JS
node_modules/
error_log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
vendor

